#!/bin/sh
# git-credential-boanclaw — git credential helper that resolves PAT from
# BoanClaw credential vault (boan-credential-filter) on demand.
#
# Usage in repo:
#   git config credential.https://github.com/arizona95/BoanClawS2Git.git.helper \
#     "boanclaw s2-github-pat arizona95"
#
# The first arg is the vault slot name. Optional second arg is the username
# (default: "arizona95"). PAT is fetched live from the credential vault for
# every git operation — never stored on disk in plaintext.
#
# Env knobs (defaults match sandbox runtime):
#   BOAN_ORG_ID                 — org slug (default: sds-corp)
#   BOAN_CREDENTIAL_FILTER_URL  — filter base URL (default: http://boan-credential-filter:8082)

set -eu

SLOT="${1:-}"
USERNAME="${2:-arizona95}"
ACTION="${3:-${1:-}}"  # if invoked as `helper SLOT get` then $3=get; legacy `helper get` works too

# Some callers pass action as the only argument when slot is in env.
case "$SLOT" in
get|store|erase)
  ACTION="$SLOT"
  SLOT="${BOAN_CREDENTIAL_SLOT:-}"
  ;;
esac

ORG="${BOAN_ORG_ID:-sds-corp}"
URL_BASE="${BOAN_CREDENTIAL_FILTER_URL:-http://boan-credential-filter:8082}"

# git sends attributes on stdin (host=, protocol=, path=, ...). We don't need
# them since the slot is the source of truth, but we must drain stdin so git
# doesn't get a SIGPIPE.
while IFS='=' read -r _k _v 2>/dev/null; do
  [ -z "$_k" ] && break
done < /dev/stdin || true

if [ "$ACTION" != "get" ]; then
  # store/erase are no-op for vault-managed credentials.
  exit 0
fi

if [ -z "$SLOT" ]; then
  echo "git-credential-boanclaw: slot name required" >&2
  exit 1
fi

# Fetch PAT from credential vault.
RESP=$(curl -fsS --max-time 5 "${URL_BASE}/credential/${ORG}/${SLOT}" 2>/dev/null || true)
if [ -z "$RESP" ]; then
  echo "git-credential-boanclaw: vault unreachable for slot=${SLOT}" >&2
  exit 0
fi

# Extract the "key" field (plaintext PAT). Use jq if available, else sed.
if command -v jq >/dev/null 2>&1; then
  PAT=$(printf '%s' "$RESP" | jq -r '.key // empty')
  STATUS=$(printf '%s' "$RESP" | jq -r '.status // empty')
else
  PAT=$(printf '%s' "$RESP" | sed -n 's/.*"key":"\([^"]*\)".*/\1/p')
  STATUS=$(printf '%s' "$RESP" | sed -n 's/.*"status":"\([^"]*\)".*/\1/p')
fi

if [ "$STATUS" != "ok" ] || [ -z "$PAT" ]; then
  echo "git-credential-boanclaw: slot=${SLOT} status=${STATUS}" >&2
  exit 0
fi

printf 'username=%s\n' "$USERNAME"
printf 'password=%s\n' "$PAT"
