# BoanClaw LLM Registry 등록용 curl 템플릿 예시
# (Admin Console → LLM Registry → 모델 등록 → 이미지 모델 모드에 붙여넣기)
#
# 등록 후 "역할 설정" 탭에서 GUI 컬럼의 + 버튼 눌러서 grounding 역할 바인딩.

# ─── MAI-UI-8B (권장 — ScreenSpot-Pro 73.5%) ─────────────────────────
curl -X POST http://YOUR-GCP-IP:8000/v1/chat/completions \
  -H "Content-Type: application/json" \
  -d '{
    "model": "grounding",
    "max_tokens": 64,
    "temperature": 0,
    "messages": [{
      "role": "user",
      "content": [
        {"type": "image_url", "image_url": {"url": "data:image/png;base64,{{IMAGE_BASE64}}"}},
        {"type": "text", "text": "{{MESSAGE}}"}
      ]
    }]
  }'

# ─── UGround-V1-2B (대안 — 더 가볍고 안정적, ScreenSpot-Pro 26.6%) ────
# bootstrap.sh 에서 MODEL=osunlp/UGround-V1-2B 로 띄웠을 때 동일 curl 사용

# ─── OS-Atlas-Base-7B (legacy) ───────────────────────────────────────
# bootstrap.sh 에서 MODEL=OS-Copilot/OS-Atlas-Base-7B 로 띄웠을 때 동일 curl 사용

# ─── 인증이 필요한 경우 (vLLM --api-key sk-xxx 옵션) ──────────────────
# 아래처럼 Authorization 헤더 추가 후 등록하면 BoanClaw credential filter 가
# sk-xxx 부분을 자동으로 감춰서 {{CREDENTIAL:grounding}} 로 치환:
#
# curl -X POST http://YOUR-GCP-IP:8000/v1/chat/completions \
#   -H "Authorization: Bearer sk-grounding-token-1234567890abcdef" \
#   -H "Content-Type: application/json" \
#   -d '{ ... 위와 동일 ... }'

# ─── 동작 검증 (등록 전 직접 호출) ────────────────────────────────────
# 1) 모델 목록:
#    curl -s http://YOUR-GCP-IP:8000/v1/models | python3 -m json.tool
